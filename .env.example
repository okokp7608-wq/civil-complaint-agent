# OpenRouter API 키 (https://openrouter.ai/keys 에서 발급)
OPENROUTER_API_KEY=sk-or-v1-여기에_본인_키

# 기본/폴백 모델 — OpenRouter 대시보드에서 실제 사용 가능한 "슬림(저가)" 모델 ID로 교체할 것.
# 이 프로젝트는 6단계 실측에서 openai/gpt-4o-mini로 검증했다. 팀/기관 예산에 맞는 다른 모델로 바꿔도 된다.
OPENROUTER_MODEL_DEFAULT=openai/gpt-4o-mini
OPENROUTER_MODEL_FALLBACK=openai/gpt-4o-mini

# 에러 핸들링 / 비용 서킷브레이커 (ADR-0002)
MAX_RETRIES=3
MAX_HOPS=12
MAX_TOKENS_TOTAL=200000

# 1이면 실제 API를 호출하지 않고 mock 응답으로 배선만 검증한다 (dry-run)
MOCK_LLM=0
